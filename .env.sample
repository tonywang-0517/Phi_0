# Copy to .env and adjust paths for your machine.
HF_ENDPOINT=https://hf-mirror.com
# HF_TOKEN=hf_xxx
SIMPLE_DATA_ROOT=./data/simple
HF_HOME=/tmp/hf
TRANSFORMERS_CACHE=/tmp/hf/transformers
# SIMPLE closed-loop eval (optional): third_party/SIMPLE Docker reads DATA_DIR
# DATA_DIR=/absolute/path/to/Phi_0/data/simple
